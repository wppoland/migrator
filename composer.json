{
    "name": "wppoland/migrator",
    "description": "Back up your WordPress site and move it to a new host. One file, drag and drop, no technical setup.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "php-stubs/woocommerce-stubs": "^10.8",
        "php-stubs/wp-cli-stubs": "^2.10",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Migrator\\": "src/"
        }
    },
    "scripts": {
        "cs": "phpcs --standard=phpcs.xml.dist",
        "cs:fix": "phpcbf --standard=phpcs.xml.dist",
        "analyse": "phpstan analyse -c phpstan.neon.dist --memory-limit=2G"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
